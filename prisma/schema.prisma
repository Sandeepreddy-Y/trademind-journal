// TradeMind Journal - Prisma Schema
// PostgreSQL database with Prisma ORM

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Users Table
// ============================================
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?  // Nullable for Google OAuth users
  avatar    String?
  provider  String   @default("email") // "email" or "google"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trades   Trade[]
  settings UserSettings?
  goals    TradingGoal[]

  @@map("users")
}

// ============================================
// Trades Table
// ============================================
model Trade {
  id          String   @id @default(cuid())
  userId      String
  ticket      Int      @unique // MT5 Position/Ticket number (unique for duplicate prevention)
  symbol      String   // e.g. EURUSD, XAUUSD
  direction   String   // "Buy" or "Sell"
  volume      Float    // Lot size
  entryPrice  Float
  exitPrice   Float
  stopLoss    Float    @default(0)
  takeProfit  Float    @default(0)
  openTime    DateTime
  closeTime   DateTime
  holdingTime Int      // Holding time in minutes (auto-calculated)
  session     String   // "Asian" | "London" | "New York" | "Overlap"
  day         String   // Day of week (e.g. "Monday")
  week        Int      // Week number of the year
  month       String   // Month name (e.g. "January")
  year        Int
  profit      Float    // Net profit/loss
  commission  Float    @default(0)
  swap        Float    @default(0)
  status      String   // "Win" | "Loss" | "Break Even" | "Open"
  riskReward  Float?   // Risk:Reward ratio (auto-calculated if SL & TP exist)
  
  // Journaling & Manual review fields
  notes              String?
  reason             String?
  logic              String?
  entryConfirmations String[] @default([])
  emotion            String?
  confidence         Int      @default(5)
  mistakes           String[] @default([])
  lessons            String?
  improvement        String?
  tags               String[] @default([])
  strategy           String?
  
  // Screenshots / Images
  beforeImage        String?
  afterImage         String?
  tvImage            String?
  mt5Image           String?
  
  // Metadata & Sync info
  source             String?  @default("manual") // "manual" | "mt5" | "broker"
  mt5PositionId      Int?
  accountNumber      Int?
  brokerName         String?
  serverName         String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([symbol])
  @@index([openTime])
  @@index([status])
  @@map("trades")
}

// ============================================
// User Settings Table
// ============================================
model UserSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  currency          String   @default("USD")
  timezone          String   @default("UTC")
  defaultRiskPct    Float    @default(1.0)
  theme             String   @default("dark")
  weeklyTarget      Float    @default(0)
  monthlyTarget     Float    @default(0)
  riskRules         String   @default("")
  tradingChecklist  String[] @default([])
  riskLimit         Float?
  defaultLotSize    Float?
  
  // Broker Integration
  brokerType        String   @default("none") // "none" | "oanda" | "xm" | "goat"
  brokerApiKey      String?
  brokerAccountId   String?
  brokerEnvironment String?
  brokerConnected   Boolean  @default(false)
  brokerLastSync    DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ============================================
// Trading Goals Table
// ============================================
model TradingGoal {
  id        String   @id @default(cuid())
  userId    String
  title     String
  target    Float
  current   Float    @default(0)
  type      String   // "weekly" | "monthly"
  deadline  DateTime
  completed Boolean  @default(false)
  metric    String   @default("pnl") // "pnl" | "winRate" | "tradeCount"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("trading_goals")
}
